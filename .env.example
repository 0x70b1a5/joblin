# Copy this file to `.env` and fill in your bot token.

# Required: your bot's token from the Discord Developer Portal
# (Applications -> your app -> Bot -> Reset/Copy Token).
DISCORD_TOKEN=

# Optional: a server (guild) id. If set, slash commands are synced to just that
# server and appear instantly — ideal while developing. Leave blank to sync
# globally (can take up to ~1 hour to propagate the first time).
DEV_GUILD_ID=

# Optional: where to keep the JSON store + completion log. Defaults to ./data
# JOBLIN_DATA_DIR=data

# Optional: extra Discord user ids (comma-separated) allowed to run /redeploy,
# in addition to the application owner (who is always allowed). Most setups can
# leave this blank.
# OWNER_IDS=
