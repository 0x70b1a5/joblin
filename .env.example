# Copy this file to `.env` and fill in your bot token.

# Required: your bot's token from the Discord Developer Portal
# (Applications -> your app -> Bot -> Reset/Copy Token).
DISCORD_TOKEN=

# Optional: a server (guild) id. If set, slash commands are synced to just that
# server and appear instantly — ideal while developing. Leave blank to sync
# globally (can take up to ~1 hour to propagate the first time).
DEV_GUILD_ID=

# Optional: where to keep the JSON store + completion log. Defaults to ./data
# JOBLIN_DATA_DIR=data

# Optional: extra Discord user ids (comma-separated) allowed to run /redeploy,
# in addition to the application owner (who is always allowed). Most setups can
# leave this blank.
# OWNER_IDS=

# --- Web UI (optional) -------------------------------------------------------
# The bot can serve a mobile-friendly schedule viewer/editor from inside the
# same process. It stays completely off unless ALL THREE of these are set.
#
# 1. WEB_BASE_URL: the public URL the site is reached at (no trailing slash),
#    e.g. https://joblin.example.com — or http://your-vps-ip:8710 to try it out.
# 2. DISCORD_CLIENT_ID / DISCORD_CLIENT_SECRET: from the Developer Portal
#    (Applications -> your app -> OAuth2). On that same page, add
#    <WEB_BASE_URL>/oauth/callback to the "Redirects" list — sign-in fails
#    without it.
# WEB_BASE_URL=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# Optional: where the web server listens (defaults: 0.0.0.0 / 8710). Point a
# reverse proxy (e.g. Caddy, for https) at this, or expose the port directly.
# WEB_HOST=0.0.0.0
# WEB_PORT=8710

# Optional: the cookie-signing secret. Leave unset to have one generated and
# saved to JOBLIN_DATA_DIR/web_secret automatically.
# WEB_SECRET=
